[Unit]
Description=Jenkins Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=jenkins
Group=jenkins
WorkingDirectory=/home/jenkins
ExecStart=/usr/bin/java -jar /home/jenkins/agent.jar -url https://jenkins.lab.sponar.de/ -tunnel 10.10.0.12:50000 -secret AGENT_SECRET -name lin-03 -workDir /home/jenkins
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
